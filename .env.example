# UNIGEST - Variabili d'Ambiente (Esempio)
# Copia questo file in .env e personalizza i valori

SECRET_KEY=cambiami-con-una-chiave-segreta
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Configurazione Database MySQL
DB_NAME=unigest_db
DB_USER=unigest_user
DB_PASSWORD=password_sicura
DB_HOST=localhost
DB_PORT=3306

# Configurazione Database VECCHIO (per migrazione dati)
OLD_DB_NAME=UNI
OLD_DB_USER=root
OLD_DB_PASSWORD=password_mysql
OLD_DB_HOST=localhost
OLD_DB_PORT=3306

# Timezone e Lingua
TIME_ZONE=Europe/Rome
LANGUAGE_CODE=it-it
