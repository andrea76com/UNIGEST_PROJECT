# --- CONFIGURAZIONE DJANGO ---
SECRET_KEY=cambiami-con-una-stringa-molto-lunga-e-segreta
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# --- CONFIGURAZIONE DATABASE (MARIADB SULL'HOST) ---
DB_NAME=unigest_db
DB_USER=unigest_user
DB_PASSWORD=unigest_password

# Per collegarsi al database installato sulla macchina HOST:
# - Su Linux (Docker standard): Usa l'IP del gateway (spesso 172.17.0.1)
# - Alternativa universale: host.docker.internal (abilitato in docker-compose)
DB_HOST=host.docker.internal
DB_PORT=3306

# --- CONFIGURAZIONE IMPORT DATI VECCHI (OPZIONALE) ---
OLD_DB_NAME=UNIPIEVE
OLD_DB_USER=root
OLD_DB_PASSWORD=
OLD_DB_HOST=host.docker.internal
